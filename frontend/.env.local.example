NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_PLATFORM_CONFIG_ADDRESS=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Same value as ATTRIBUTION_TAG below, exposed to the browser bundle so
# wallet-signed transactions (create/deposit/withdraw/admin) can carry it
# too — see lib/attribution.ts and lib/useTaggedWriteContract.ts. Not a
# secret: it's meant to be public on every tagged transaction.
NEXT_PUBLIC_ATTRIBUTION_TAG=

# --- keeper (server-only, never prefix with NEXT_PUBLIC_) ---
# Same operator wallet the old agent/.env used.
OPERATOR_PRIVATE_KEY=
CELO_RPC_URL=https://forno.celo.org
# Server-side Arbitrum RPC for the keeper/indexer's own eth_getLogs-heavy
# scans (lib/dashboard/indexer.ts, lib/keeper/discovery.ts) — needs large
# block ranges, so leave this as a plain public RPC (e.g.
# https://arb1.arbitrum.io/rpc); an Alchemy free-tier key here caps
# eth_getLogs at 10 blocks and will break vault/event discovery.
ARBITRUM_RPC_URL=

# Dedicated Arbitrum RPC for LIVE client reads only (e.g. Alchemy —
# https://arb-mainnet.g.alchemy.com/v2/<key>), backing app/api/rpc/arbitrum's
# proxy — see wagmi.ts. Deliberately separate from ARBITRUM_RPC_URL above:
# sharing one var between the two is a real cost bug (confirmed in
# production 2026-07-24 — see that route's own docstring), not just a naming
# nitpick. Public Arbitrum RPCs are used as automatic fallback if this is
# unset. Server-only on purpose — the browser reaches this indirectly
# through the same-origin proxy route.
ARBITRUM_CLIENT_RPC_URL=
ATTRIBUTION_TAG=

# Supabase (Vercel Marketplace integration, free tier) — replaces the old
# agent/data/store.json now that the keeper runs as a stateless serverless
# function. Connect at vercel.com → project → Storage → Marketplace Database →
# Supabase, which fills SUPABASE_URL/NEXT_PUBLIC_SUPABASE_URL and
# SUPABASE_SERVICE_ROLE_KEY in automatically; only needed manually for local
# dev. Run lib/keeper/schema.sql once in the Supabase SQL Editor after
# connecting — it's not applied automatically.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the GitHub Actions cron workflow sends as `Authorization: Bearer
# <value>` when it POSTs /api/cron/tick every 5 minutes. Generate with
# `openssl rand -hex 32`; set the same value as the CRON_SECRET GitHub secret.
CRON_SECRET=

# Signs/verifies the SIWE session cookie issued by /api/auth/verify (see
# lib/auth/session.ts) and, from the same key, the stateless nonce used
# during sign-in. Generate with `openssl rand -hex 32`. Required for the
# referral system's auth endpoints (/api/auth/*, /api/referral/*,
# /api/admin/referral-overview) — the rest of the app works without it.
# Also run lib/referrals/schema.sql once in the Supabase SQL Editor before
# using those endpoints (same manual step as lib/keeper/schema.sql).
AUTH_JWT_SECRET=

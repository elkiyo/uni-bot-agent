NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_PLATFORM_CONFIG_ADDRESS=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- keeper (server-only, never prefix with NEXT_PUBLIC_) ---
# Same operator wallet the old agent/.env used.
OPERATOR_PRIVATE_KEY=
CELO_RPC_URL=https://forno.celo.org
# Dedicated Arbitrum RPC (e.g. Alchemy — https://arb-mainnet.g.alchemy.com/v2/<key>).
# Public Arbitrum RPCs are used as automatic fallback if this is unset; see
# wagmi.ts and app/api/rpc/arbitrum/route.ts. Server-only on purpose — the
# browser reaches this indirectly through the same-origin proxy route.
ARBITRUM_RPC_URL=
ATTRIBUTION_TAG=

# Supabase (Vercel Marketplace integration, free tier) — replaces the old
# agent/data/store.json now that the keeper runs as a stateless serverless
# function. Connect at vercel.com → project → Storage → Marketplace Database →
# Supabase, which fills SUPABASE_URL/NEXT_PUBLIC_SUPABASE_URL and
# SUPABASE_SERVICE_ROLE_KEY in automatically; only needed manually for local
# dev. Run lib/keeper/schema.sql once in the Supabase SQL Editor after
# connecting — it's not applied automatically.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the GitHub Actions cron workflow sends as `Authorization: Bearer
# <value>` when it POSTs /api/cron/tick every 5 minutes. Generate with
# `openssl rand -hex 32`; set the same value as the CRON_SECRET GitHub secret.
CRON_SECRET=

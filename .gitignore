# contracts (Foundry)
contracts/cache/
contracts/out/
contracts/broadcast/
# contracts/lib/ is intentionally committed, not ignored: dependencies were
# installed with `forge install --no-git` (see contracts/README.md — avoids the
# OZ default-branch/submodule-conflict issues we hit), so there is no manifest
# a fresh clone or CI run could use to reinstall them. Committing them directly
# makes `forge build`/`forge test` work immediately after checkout, no install
# step, no version-drift risk.

# agent / frontend (Node)
node_modules/
dist/
.next/
*.tsbuildinfo
agent/data/

# env
.env
.env.local
*.env.local

# OS
.DS_Store

# agent skill installer artifacts (npx skills add) — reinstall via PLAN.md step 1
.agents/
.claude/
skills-lock.json
